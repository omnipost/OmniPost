<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- ios/OmniPost/Info.plist -->
<plist version="1.0">
<dict>

    <!-- ── App Identity ──────────────────────────────────────── -->
    <key>CFBundleDisplayName</key>        <string>OmniPost</string>
    <key>CFBundleIdentifier</key>         <string>com.omnipost.app</string>
    <key>CFBundleVersion</key>            <string>1</string>
    <key>CFBundleShortVersionString</key> <string>1.0.0</string>

    <!-- ── Privacy Permissions ───────────────────────────────── -->
    <key>NSCameraUsageDescription</key>
    <string>OmniPost needs camera access to capture photos and videos for your social media posts.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>OmniPost needs photo library access to select images and videos for your posts.</string>

    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>OmniPost needs permission to save media to your photo library.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>OmniPost needs microphone access to record videos with audio for your posts.</string>

    <!-- ── URL Schemes for OAuth callbacks ───────────────────── -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>omnipost</string>
                <!-- Add your Facebook app scheme: fb{APP_ID} -->
                <string>fbREPLACE_WITH_META_APP_ID</string>
            </array>
        </dict>
    </array>

    <!-- ── Facebook SDK ──────────────────────────────────────── -->
    <key>FacebookAppID</key>             <string>REPLACE_WITH_META_APP_ID</string>
    <key>FacebookClientToken</key>       <string>REPLACE_WITH_META_CLIENT_TOKEN</string>
    <key>FacebookDisplayName</key>       <string>OmniPost</string>

    <!-- ── App Transport Security ────────────────────────────── -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key> <true/>
        <!-- Remove NSAllowsArbitraryLoads in production -->
        <key>NSAllowsArbitraryLoads</key>  <false/>
    </dict>

    <!-- ── Background Modes ──────────────────────────────────── -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>background-fetch</string>
    </array>

    <!-- ── UI ────────────────────────────────────────────────── -->
    <key>UIStatusBarStyle</key>         <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key> <false/>
    <key>UIRequiresFullScreen</key>     <true/>
    <key>UILaunchStoryboardName</key>   <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>     <string>Main</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

</dict>
</plist>
