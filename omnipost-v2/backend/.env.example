# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ────────────────────────────────────────────────
# Set your Atlas or local connection string here
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=omnipost_db
# Optional local fallback when Atlas is unreachable
MONGODB_FALLBACK_URI=mongodb://localhost:27017/omnipost_db?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email (SMTP — for password reset) ──────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@omnipost.in

# ─── SMS OTP (MSG91) — optional ─────────────────────────────
MSG91_AUTH_KEY=REPLACE_WITH_MSG91_KEY
MSG91_SENDER_ID=OMNIPST
MSG91_TEMPLATE_ID=REPLACE_WITH_TEMPLATE_ID

# ─── Redis — optional (for queues) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 / Media — optional ──────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
AWS_REGION=ap-south-1
AWS_S3_BUCKET=omnipost-media

# ─── Razorpay (Billing) — optional ──────────────────────────
RAZORPAY_KEY_ID=REPLACE_WITH_RAZORPAY_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET

# ─── Social Platform API Credentials — optional ─────────────
META_APP_ID=REPLACE_WITH_META_APP_ID
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET
TWITTER_CLIENT_ID=REPLACE_WITH_TWITTER_CLIENT_ID
TWITTER_CLIENT_SECRET=REPLACE_WITH_TWITTER_CLIENT_SECRET
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
LINKEDIN_CLIENT_ID=REPLACE_WITH_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=REPLACE_WITH_LINKEDIN_CLIENT_SECRET

# ─── Encryption key for tokens — optional ───────────────────
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_KEY
