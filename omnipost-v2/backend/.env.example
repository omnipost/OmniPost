# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database (PostgreSQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omnipost_db
DB_USER=omnipost_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 / Media ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
AWS_REGION=ap-south-1
AWS_S3_BUCKET=omnipost-media

# ─── SMS OTP (MSG91) ─────────────────────────────────────────
MSG91_AUTH_KEY=REPLACE_WITH_MSG91_KEY
MSG91_SENDER_ID=OMNIPST
MSG91_TEMPLATE_ID=REPLACE_WITH_TEMPLATE_ID

# ─── Email (AWS SES or SMTP) ─────────────────────────────────
EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USER=REPLACE_WITH_SMTP_USER
EMAIL_PASS=REPLACE_WITH_SMTP_PASS
EMAIL_FROM=noreply@omnipost.in

# ─── Firebase (Push Notifications) ───────────────────────────
FIREBASE_PROJECT_ID=REPLACE_WITH_PROJECT_ID
FIREBASE_CLIENT_EMAIL=REPLACE_WITH_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY=REPLACE_WITH_PRIVATE_KEY

# ─── Razorpay (Billing) ──────────────────────────────────────
RAZORPAY_KEY_ID=REPLACE_WITH_RAZORPAY_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET

# ─── Social Platform API Credentials ────────────────────────
# Meta (Instagram + Facebook + Threads)
META_APP_ID=REPLACE_WITH_META_APP_ID
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET
META_REDIRECT_URI=http://localhost:4000/api/oauth/callback/instagram

# Twitter / X
TWITTER_CLIENT_ID=REPLACE_WITH_TWITTER_CLIENT_ID
TWITTER_CLIENT_SECRET=REPLACE_WITH_TWITTER_CLIENT_SECRET
TWITTER_REDIRECT_URI=http://localhost:4000/api/oauth/callback/twitter

# Google (YouTube)
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:4000/api/oauth/callback/youtube

# LinkedIn
LINKEDIN_CLIENT_ID=REPLACE_WITH_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=REPLACE_WITH_LINKEDIN_CLIENT_SECRET
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/oauth/callback/linkedin

# ShareChat
SHARECHAT_API_KEY=REPLACE_WITH_SHARECHAT_KEY
SHARECHAT_API_SECRET=REPLACE_WITH_SHARECHAT_SECRET

# ─── Encryption key for tokens ───────────────────────────────
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_KEY
